# Copy this file to .env and fill in your values for local development
# NEVER commit .env to git!

# Server Configuration
NODE_ENV=development
PORT=3000

# Google Sheets Integration
GOOGLE_SHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEET_NAME=Sheet1

# Google Service Account (for development only - use env variables in production)
# Either use file path OR the JSON environment variable
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json
# OR provide the entire JSON as a string:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Optional: Define custom columns for Google Sheets
GOOGLE_SHEET_COLUMNS=timestamp,reporterEmail,reporterName,reporterPin,reporterPhone,supervisor1Name,supervisor2Name,component,project,zonalArea,dmArea,branchName,phase,errorCategory,errorType,issueDescription,attachment
