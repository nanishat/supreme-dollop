{
  "buildCommand": "cd backend && npm install && cd ../frontend && npm install && npm run build && cd ..",
  "outputDirectory": "frontend/dist",
  "framework": "other",
  "functions": {
    "backend/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "backend/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
